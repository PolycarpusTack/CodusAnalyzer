// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Authentication (NextAuth.js)
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  githubId      String?   @unique
  role          String    @default("USER") // USER, ADMIN

  accounts      Account[]
  sessions      Session[]
  apiKeys       ApiKey[]
  reviews       CodeReview[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiKey {
  id        String    @id @default(cuid())
  name      String
  keyHash   String    @unique  // SHA-256 hash of the full key
  keyPrefix String              // e.g. "ca_live_abc12" — visible prefix for identification
  userId    String
  rateLimit Int       @default(60) // requests per minute
  expiresAt DateTime?
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// GitHub App
// ---------------------------------------------------------------------------

model GitHubInstallation {
  id              String   @id @default(cuid())
  installationId  Int      @unique
  accountLogin    String
  accountType     String   // "User" or "Organization"
  tokenCache      String?  // JSON: { token, expiresAt }

  repositories    GitHubRepository[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GitHubRepository {
  id              String   @id @default(cuid())
  installationId  String
  installation    GitHubInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  owner           String
  name            String
  fullName        String   @unique // "owner/name"
  reviewEnabled   Boolean  @default(true)
  reviewPreset    String   @default("full")
  autoReview      Boolean  @default(true)
  minSeverity     String   @default("warning")
  maxComments     Int      @default(30)

  prReviews       GitHubPRReview[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GitHubPRReview {
  id            String   @id @default(cuid())
  repositoryId  String
  repository    GitHubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  prNumber      Int
  headSha       String
  checkRunId    String?
  reviewId      String?  // GitHub review ID
  status        String   @default("pending") // pending, in_progress, completed, failed
  qualityScore  Float?
  findingsCount Int      @default(0)
  errorMessage  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Code Reviews
// ---------------------------------------------------------------------------

model CodeReview {
  id          String   @id @default(cuid())
  codeContent String
  language    String
  fileName    String?

  // Optional user association
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Review results
  summary          String?
  positiveAspects  String?   // JSON array of strings
  qualityScore     Float?
  totalLines  Int?
  passed      Boolean  @default(false)

  // Counts
  criticalCount Int     @default(0)
  errorCount    Int     @default(0)
  warningCount  Int     @default(0)
  infoCount     Int     @default(0)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  findings   CodeReviewFinding[]

  @@index([userId])
}

model CodeReviewFinding {
  id            String   @id @default(cuid())
  reviewId      String
  review        CodeReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  ruleId        String
  severity      String    // critical, error, warning, info, hint
  category      String    // bug, security, performance, maintainability, style, testing
  message       String

  lineStart     Int?
  lineEnd       Int?
  columnStart   Int?
  columnEnd     Int?
  codeSnippet   String?

  suggestion    String?
  explanation   String?
  documentation String?

  autoFixable   Boolean  @default(false)
  fixed         Boolean  @default(false)

  resolution    String   @default("open")  // open, fixed, wont_fix, false_positive
  resolvedAt    DateTime?

  createdAt     DateTime @default(now())
}
